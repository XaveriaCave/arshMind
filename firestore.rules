rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Validation
    function isValidUserProfile(data) {
      let requiredFields = ['userId', 'name', 'createdAt', 'updatedAt'];
      return data.keys().hasAll(requiredFields)
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (data.get('age', 25) is number)
        && (data.get('salary', 0) is number)
        && (data.get('bankBalance', 0) is number)
        && (data.get('monthlySavings', 0) is number)
        && (data.get('assets', []) is list)
        && (data.get('loans', []) is list)
        && (data.get('goals', []) is list)
        && (data.get('updatedAt', request.time) == request.time);
    }

    // Settings Validation
    function isValidSettings(data) {
      let requiredFields = ['activeScenarioId', 'savingsRate', 'salaryGrowth', 'investmentReturn', 'updatedAt'];
      return data.keys().hasAll(requiredFields)
        && data.activeScenarioId is string
        && data.savingsRate is number
        && data.salaryGrowth is number
        && data.investmentReturn is number
        && data.updatedAt == request.time;
    }

    // Scenario Data Validation
    function isValidScenarioData(data) {
      let requiredFields = ['scenarios', 'updatedAt'];
      return data.keys().hasAll(requiredFields)
        && data.scenarios is list
        && data.updatedAt == request.time;
    }

    match /test/connection {
      allow get: if true;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isEmailVerified()
        && isValidUserProfile(incoming()) 
        && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId) && isEmailVerified()
        && isValidUserProfile(incoming())
        && incoming().createdAt == existing().createdAt;

      match /settings/current {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isEmailVerified() 
          && isValidSettings(incoming())
          && exists(/databases/$(database)/documents/users/$(userId));
      }

      match /scenarios/latest {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isEmailVerified() 
          && isValidScenarioData(incoming())
          && exists(/databases/$(database)/documents/users/$(userId));
      }
    }
  }
}
